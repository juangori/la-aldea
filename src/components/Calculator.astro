---
---
<section class="calculator" id="calculadora">
  <div class="container">
    <div class="section-title fade-in">
      <h2>Calculadora de <span class="accent">Hielo</span></h2>
      <div class="section-divider"></div>
      <p>Calculá cuánto hielo necesitás para tu evento. ¡No te quedes corto!</p>
    </div>
    <div class="calc-wrapper fade-in">
      <div class="calc-card">
        <div class="calc-form">
          <div class="form-group">
            <label for="personas">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
              Cantidad de personas
            </label>
            <input type="number" id="personas" min="1" max="10000" value="50" />
          </div>

          <div class="form-group">
            <label>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Estación del año
            </label>
            <div class="radio-group" id="estacion">
              <label class="radio-card">
                <input type="radio" name="estacion" value="verano" checked />
                <div class="radio-content">
                  <span class="radio-icon">☀️</span>
                  <span>Verano</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="estacion" value="primavera" />
                <div class="radio-content">
                  <span class="radio-icon">🌸</span>
                  <span>Primavera</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="estacion" value="otono" />
                <div class="radio-content">
                  <span class="radio-icon">🍂</span>
                  <span>Otoño</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="estacion" value="invierno" />
                <div class="radio-content">
                  <span class="radio-icon">❄️</span>
                  <span>Invierno</span>
                </div>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Tipo de evento
            </label>
            <div class="radio-group" id="evento">
              <label class="radio-card">
                <input type="radio" name="evento" value="casual" checked />
                <div class="radio-content">
                  <span class="radio-icon">🏠</span>
                  <span>Juntada</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="evento" value="asado" />
                <div class="radio-content">
                  <span class="radio-icon">🔥</span>
                  <span>Asado</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="evento" value="fiesta" />
                <div class="radio-content">
                  <span class="radio-icon">🎉</span>
                  <span>Fiesta</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="evento" value="evento" />
                <div class="radio-content">
                  <span class="radio-icon">🎪</span>
                  <span>Evento grande</span>
                </div>
              </label>
            </div>
          </div>

          <button class="btn-calc" id="calcular">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
            Calcular
          </button>
        </div>

        <div class="calc-result" id="resultado">
          <div class="result-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--gray-200)" stroke-width="1">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            <p>Completá los datos y presioná <strong>Calcular</strong></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .calculator {
    padding: 120px 0;
    background: var(--white);
  }

  .calc-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  .calc-card {
    background: var(--white);
    border-radius: 24px;
    border: 1px solid var(--gray-200);
    overflow: hidden;
    box-shadow: 0 10px 60px rgba(0,0,0,0.06);
  }

  .calc-form {
    padding: 40px;
  }

  .form-group {
    margin-bottom: 28px;
  }

  .form-group > label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--gray-800);
    margin-bottom: 12px;
  }

  .form-group > label svg {
    color: var(--red);
  }

  input[type="number"] {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid var(--gray-200);
    border-radius: 12px;
    font-size: 1.1rem;
    font-family: 'Outfit', sans-serif;
    transition: border-color 0.3s ease;
    outline: none;
    -moz-appearance: textfield;
  }

  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  input[type="number"]:focus {
    border-color: var(--red);
  }

  .radio-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 10px;
  }

  .radio-card {
    cursor: pointer;
  }

  .radio-card input {
    display: none;
  }

  .radio-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 8px;
    border: 2px solid var(--gray-200);
    border-radius: 12px;
    transition: all 0.3s ease;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--gray-600);
  }

  .radio-icon {
    font-size: 1.4rem;
  }

  .radio-card input:checked + .radio-content {
    border-color: var(--red);
    background: rgba(196, 30, 42, 0.04);
    color: var(--red);
  }

  .radio-content:hover {
    border-color: var(--red-light);
  }

  .btn-calc {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px;
    background: var(--red);
    color: var(--white);
    border: none;
    border-radius: 12px;
    font-size: 1.05rem;
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 8px;
  }

  .btn-calc:hover {
    background: var(--red-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(196, 30, 42, 0.3);
  }

  .calc-result {
    background: var(--off-white);
    padding: 40px;
    border-top: 1px solid var(--gray-200);
  }

  .result-placeholder {
    text-align: center;
    color: var(--gray-400);
    padding: 20px;
  }

  .result-placeholder p {
    margin-top: 16px;
    font-size: 0.95rem;
  }

  :global(.result-display) {
    text-align: center;
    animation: fadeInUp 0.5s ease;
  }

  :global(.result-number) {
    font-family: 'Outfit', sans-serif;
    font-size: 4rem;
    font-weight: 900;
    color: var(--red);
    line-height: 1;
  }

  :global(.result-unit) {
    font-size: 1.2rem;
    color: var(--gray-600);
    margin-top: 4px;
    font-weight: 500;
  }

  :global(.result-detail) {
    margin-top: 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  :global(.detail-item) {
    background: var(--white);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
    border: 1px solid var(--gray-200);
  }

  :global(.detail-value) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gray-800);
    font-family: 'Outfit', sans-serif;
  }

  :global(.detail-label) {
    font-size: 0.78rem;
    color: var(--gray-400);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  :global(.result-tip) {
    margin-top: 20px;
    padding: 14px 20px;
    background: rgba(196, 30, 42, 0.06);
    border-radius: 10px;
    font-size: 0.88rem;
    color: var(--gray-600);
    border-left: 3px solid var(--red);
  }

  :global(.result-cta) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding: 12px 28px;
    background: var(--red);
    color: white;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  :global(.result-cta:hover) {
    background: var(--red-dark);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .calculator {
      padding: 80px 0;
    }

    .calc-form,
    .calc-result {
      padding: 24px;
    }

    .radio-group {
      grid-template-columns: repeat(2, 1fr);
    }

    :global(.result-number) {
      font-size: 3rem;
    }

    :global(.result-detail) {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const calcBtn = document.getElementById('calcular')!;
  const resultado = document.getElementById('resultado')!;

  // kg de hielo por persona según estación
  const factorEstacion: Record<string, number> = {
    verano: 1.5,
    primavera: 1.0,
    otono: 0.7,
    invierno: 0.5
  };

  // multiplicador según tipo de evento
  const factorEvento: Record<string, number> = {
    casual: 0.8,
    asado: 1.0,
    fiesta: 1.3,
    evento: 1.5
  };

  const nombreEstacion: Record<string, string> = {
    verano: 'verano',
    primavera: 'primavera',
    otono: 'otoño',
    invierno: 'invierno'
  };

  const nombreEvento: Record<string, string> = {
    casual: 'juntada',
    asado: 'asado',
    fiesta: 'fiesta',
    evento: 'evento grande'
  };

  calcBtn.addEventListener('click', () => {
    const personas = parseInt((document.getElementById('personas') as HTMLInputElement).value) || 0;
    if (personas <= 0) return;

    const estacion = (document.querySelector('input[name="estacion"]:checked') as HTMLInputElement).value;
    const evento = (document.querySelector('input[name="evento"]:checked') as HTMLInputElement).value;

    const kgPorPersona = factorEstacion[estacion] * factorEvento[evento];
    const totalKg = Math.ceil(personas * kgPorPersona);
    const bolsas4kg = Math.ceil(totalKg / 4);
    const bolsas20kg = Math.ceil(totalKg / 20);

    resultado.innerHTML = `
      <div class="result-display">
        <div class="result-number">${totalKg} kg</div>
        <div class="result-unit">de hielo necesitás</div>
        <div class="result-detail">
          <div class="detail-item">
            <div class="detail-value">${bolsas4kg}</div>
            <div class="detail-label">Bolsas de 4kg</div>
          </div>
          <div class="detail-item">
            <div class="detail-value">${bolsas20kg}</div>
            <div class="detail-label">Bolsas de 20kg</div>
          </div>
          <div class="detail-item">
            <div class="detail-value">${kgPorPersona.toFixed(1)} kg</div>
            <div class="detail-label">Por persona</div>
          </div>
        </div>
        <div class="result-tip">
          💡 Para ${personas} personas en ${nombreEstacion[estacion]} con tipo de evento <strong>${nombreEvento[evento]}</strong>, te recomendamos tener un 10% extra por las dudas.
        </div>
        <a href="#contacto" class="result-cta">
          Pedí tu hielo ahora
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    `;
  });
</script>
