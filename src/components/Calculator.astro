---
---
<section class="calculator" id="calculadora">
  <div class="calc-bg">
    <div class="calc-orb calc-orb-1"></div>
    <div class="calc-orb calc-orb-2"></div>
  </div>
  <div class="container">
    <div class="section-title fade-in">
      <h2 class="dark-title">Calculadora de <span class="accent">Hielo</span></h2>
      <div class="section-divider"></div>
      <p class="dark-subtitle">Calculá cuánto hielo necesitás para tu evento</p>
    </div>
    <div class="calc-wrapper fade-in">
      <div class="calc-card">
        <div class="calc-form">
          <div class="form-group">
            <label for="personas">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
              Cantidad de personas
            </label>
            <input type="number" id="personas" min="1" max="10000" value="50" />
          </div>

          <div class="form-group">
            <label>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Estación del año
            </label>
            <div class="radio-group" id="estacion">
              <label class="radio-card">
                <input type="radio" name="estacion" value="verano" checked />
                <div class="radio-content">
                  <span class="radio-emoji">☀️</span>
                  <span class="radio-label">Verano</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="estacion" value="primavera" />
                <div class="radio-content">
                  <span class="radio-emoji">🌸</span>
                  <span class="radio-label">Primavera</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="estacion" value="otono" />
                <div class="radio-content">
                  <span class="radio-emoji">🍂</span>
                  <span class="radio-label">Otoño</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="estacion" value="invierno" />
                <div class="radio-content">
                  <span class="radio-emoji">❄️</span>
                  <span class="radio-label">Invierno</span>
                </div>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Tipo de evento
            </label>
            <div class="radio-group" id="evento">
              <label class="radio-card">
                <input type="radio" name="evento" value="casual" checked />
                <div class="radio-content">
                  <span class="radio-emoji">🏠</span>
                  <span class="radio-label">Juntada</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="evento" value="asado" />
                <div class="radio-content">
                  <span class="radio-emoji">🔥</span>
                  <span class="radio-label">Asado</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="evento" value="fiesta" />
                <div class="radio-content">
                  <span class="radio-emoji">🎉</span>
                  <span class="radio-label">Fiesta</span>
                </div>
              </label>
              <label class="radio-card">
                <input type="radio" name="evento" value="evento" />
                <div class="radio-content">
                  <span class="radio-emoji">🎪</span>
                  <span class="radio-label">Evento grande</span>
                </div>
              </label>
            </div>
          </div>

          <button class="btn-calc" id="calcular">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
            Calcular
          </button>
        </div>

        <div class="calc-result" id="resultado">
          <div class="result-placeholder">
            <div class="placeholder-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <p>Completá los datos y presioná <strong>Calcular</strong></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .calculator {
    padding: var(--section-pad) 0;
    background: var(--surface-dark);
    position: relative;
    overflow: hidden;
  }

  .calc-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .calc-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .calc-orb-1 {
    width: 400px;
    height: 400px;
    background: rgba(230, 57, 70, 0.06);
    top: -100px;
    right: -100px;
  }

  .calc-orb-2 {
    width: 300px;
    height: 300px;
    background: rgba(142, 202, 230, 0.04);
    bottom: -80px;
    left: -80px;
  }

  .dark-title {
    color: var(--white) !important;
  }

  .dark-subtitle {
    color: rgba(255,255,255,0.4) !important;
  }

  .calc-wrapper {
    max-width: 880px;
    margin: 0 auto;
  }

  .calc-card {
    background: rgba(255,255,255,0.03);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    backdrop-filter: blur(12px);
  }

  .calc-form {
    padding: 40px;
  }

  .form-group {
    margin-bottom: 28px;
  }

  .form-group > label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.8);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  .form-group > label svg {
    color: var(--red);
    opacity: 0.8;
  }

  input[type="number"] {
    width: 100%;
    padding: 14px 18px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    font-size: 1.05rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    transition: all 0.3s ease;
    outline: none;
    -moz-appearance: textfield;
    background: rgba(255,255,255,0.04);
    color: var(--white);
  }

  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  input[type="number"]:focus {
    border-color: var(--red);
    box-shadow: 0 0 0 3px rgba(230, 57, 70, 0.12);
  }

  .radio-group {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .radio-card {
    cursor: pointer;
  }

  .radio-card input {
    display: none;
  }

  .radio-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 8px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    background: rgba(255,255,255,0.02);
  }

  .radio-emoji {
    font-size: 1.3rem;
    line-height: 1;
  }

  .radio-label {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255,255,255,0.45);
    transition: color 0.3s ease;
  }

  .radio-card input:checked + .radio-content {
    border-color: var(--red);
    background: rgba(230, 57, 70, 0.08);
    box-shadow: 0 0 0 1px rgba(230, 57, 70, 0.2);
  }

  .radio-card input:checked + .radio-content .radio-label {
    color: var(--red);
  }

  .radio-content:hover {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
  }

  .btn-calc {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px;
    background: var(--red);
    color: var(--white);
    border: none;
    border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    margin-top: 8px;
  }

  .btn-calc:hover {
    background: var(--red-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(230, 57, 70, 0.35);
  }

  .calc-result {
    background: rgba(255,255,255,0.02);
    padding: 40px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .result-placeholder {
    text-align: center;
    color: rgba(255,255,255,0.2);
    padding: 16px;
  }

  .placeholder-icon {
    margin-bottom: 12px;
    opacity: 0.3;
  }

  .result-placeholder p {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.25);
  }

  .result-placeholder strong {
    color: rgba(255,255,255,0.4);
  }

  /* Result display styles (global because they're injected dynamically) */
  :global(.result-display) {
    text-align: center;
    animation: scaleIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(.result-number) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 800;
    color: var(--red);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  :global(.result-unit) {
    font-size: 1rem;
    color: rgba(255,255,255,0.4);
    margin-top: 6px;
    font-weight: 400;
  }

  :global(.result-detail) {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  :global(.detail-item) {
    background: rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 18px 12px;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.06);
  }

  :global(.detail-value) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
  }

  :global(.detail-label) {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.35);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
  }

  :global(.result-tip) {
    margin-top: 24px;
    padding: 14px 20px;
    background: rgba(230, 57, 70, 0.06);
    border-radius: 10px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    border-left: 3px solid var(--red);
    text-align: left;
  }

  :global(.result-tip strong) {
    color: rgba(255,255,255,0.7);
  }

  :global(.result-cta) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    padding: 13px 28px;
    background: var(--red);
    color: white;
    border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: all 0.35s ease;
  }

  :global(.result-cta:hover) {
    background: var(--red-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(230, 57, 70, 0.3);
  }

  @media (max-width: 768px) {
    .calc-form,
    .calc-result {
      padding: 24px;
    }

    .radio-group {
      grid-template-columns: repeat(2, 1fr);
    }

    :global(.result-number) {
      font-size: 3rem;
    }

    :global(.result-detail) {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>

<script>
  const calcBtn = document.getElementById('calcular')!;
  const resultado = document.getElementById('resultado')!;

  const factorEstacion: Record<string, number> = {
    verano: 1.5,
    primavera: 1.0,
    otono: 0.7,
    invierno: 0.5
  };

  const factorEvento: Record<string, number> = {
    casual: 0.8,
    asado: 1.0,
    fiesta: 1.3,
    evento: 1.5
  };

  const nombreEstacion: Record<string, string> = {
    verano: 'verano',
    primavera: 'primavera',
    otono: 'otoño',
    invierno: 'invierno'
  };

  const nombreEvento: Record<string, string> = {
    casual: 'juntada',
    asado: 'asado',
    fiesta: 'fiesta',
    evento: 'evento grande'
  };

  calcBtn.addEventListener('click', () => {
    const personas = parseInt((document.getElementById('personas') as HTMLInputElement).value) || 0;
    if (personas <= 0) return;

    const estacion = (document.querySelector('input[name="estacion"]:checked') as HTMLInputElement).value;
    const evento = (document.querySelector('input[name="evento"]:checked') as HTMLInputElement).value;

    const kgPorPersona = factorEstacion[estacion] * factorEvento[evento];
    const totalKg = Math.ceil(personas * kgPorPersona);
    const bolsas4kg = Math.ceil(totalKg / 4);
    const bolsas20kg = Math.ceil(totalKg / 20);

    resultado.innerHTML = `
      <div class="result-display">
        <div class="result-number">${totalKg} kg</div>
        <div class="result-unit">de hielo necesitás</div>
        <div class="result-detail">
          <div class="detail-item">
            <div class="detail-value">${bolsas4kg}</div>
            <div class="detail-label">Bolsas de 4kg</div>
          </div>
          <div class="detail-item">
            <div class="detail-value">${bolsas20kg}</div>
            <div class="detail-label">Bolsas de 20kg</div>
          </div>
          <div class="detail-item">
            <div class="detail-value">${kgPorPersona.toFixed(1)} kg</div>
            <div class="detail-label">Por persona</div>
          </div>
        </div>
        <div class="result-tip">
          💡 Para ${personas} personas en ${nombreEstacion[estacion]} con tipo de evento <strong>${nombreEvento[evento]}</strong>, te recomendamos tener un 10% extra por las dudas.
        </div>
        <a href="#contacto" class="result-cta">
          Pedí tu hielo ahora
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    `;
  });
</script>
