---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <img src="/logo.png" alt="La Aldea" class="footer-logo" />
        <p>Fábrica de hielo, productos congelados y distribución. Calidad y compromiso desde el primer día.</p>
      </div>
      <div class="footer-links">
        <h4>Navegación</h4>
        <a href="#hero">Inicio</a>
        <a href="#servicios">Servicios</a>
        <a href="#calculadora">Calculadora</a>
        <a href="#contacto">Contacto</a>
      </div>
      <div class="footer-social">
        <h4>Seguinos</h4>
        <a href="https://instagram.com/tu_usuario" target="_blank" class="social-link">
          <div class="social-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <span>Instagram</span>
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} La Aldea — Hielo & Congelados</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gray-900);
    color: rgba(255,255,255,0.4);
    padding: 64px 0 0;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .footer-brand {
    max-width: 300px;
  }

  .footer-logo {
    height: 52px;
    border-radius: 50%;
    margin-bottom: 16px;
    filter: grayscale(0.2);
    transition: filter 0.3s ease;
  }

  .footer-logo:hover {
    filter: grayscale(0);
  }

  .footer-brand p {
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.3);
  }

  .footer-links h4,
  .footer-social h4 {
    font-family: 'Syne', sans-serif;
    color: rgba(255,255,255,0.7);
    font-weight: 700;
    font-size: 0.82rem;
    margin-bottom: 20px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.35);
    transition: all 0.3s ease;
    font-weight: 400;
  }

  .footer-links a:hover {
    color: var(--white);
    transform: translateX(3px);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.35);
    transition: all 0.3s ease;
  }

  .social-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    color: var(--white);
  }

  .social-link:hover .social-icon {
    background: rgba(230, 57, 70, 0.12);
    border-color: rgba(230, 57, 70, 0.2);
    color: var(--red);
  }

  .footer-bottom {
    padding: 20px 0;
    text-align: center;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.5px;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 48px 0 0;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 32px;
    }
  }
</style>
