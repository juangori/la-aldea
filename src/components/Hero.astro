---
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <!-- Ambient glow orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="snow-container" id="snow-container"></div>
    <div class="mountains">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="none" class="mountain-svg mountain-back">
        <path d="M0,400 L0,280 L200,180 L350,250 L500,120 L650,220 L720,100 L850,200 L1000,80 L1100,180 L1200,130 L1350,220 L1440,160 L1440,400 Z" fill="rgba(230,57,70,0.12)" />
      </svg>
      <svg viewBox="0 0 1440 400" preserveAspectRatio="none" class="mountain-svg mountain-front">
        <path d="M0,400 L0,320 L150,240 L280,300 L420,180 L550,280 L700,150 L800,260 L950,140 L1100,250 L1250,190 L1440,280 L1440,400 Z" fill="rgba(230,57,70,0.22)" />
        <!-- Snow caps with frost blue -->
        <path d="M420,180 L455,208 L437,198 L420,208 L403,198 L385,208 Z" fill="rgba(142,202,230,0.5)" />
        <path d="M700,150 L735,178 L717,168 L700,178 L683,168 L665,178 Z" fill="rgba(142,202,230,0.5)" />
        <path d="M950,140 L985,168 L967,158 L950,168 L933,158 L915,168 Z" fill="rgba(142,202,230,0.6)" />
      </svg>
    </div>
  </div>

  <div class="hero-content container">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Fábrica & Distribución
    </div>
    <h1>
      <span class="hero-line-1">Hielo &</span>
      <span class="hero-line-2">Congelados</span>
    </h1>
    <p class="hero-subtitle">
      Producimos y distribuimos hielo y productos congelados de la más alta calidad para tu negocio, evento o consumo diario.
    </p>
    <div class="hero-cta">
      <a href="#contacto" class="btn btn-primary">
        <span>Contactanos</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="#calculadora" class="btn btn-ghost">
        <span>Calcular hielo</span>
      </a>
    </div>
  </div>

  <div class="hero-scroll">
    <a href="#servicios" aria-label="Ir a servicios">
      <div class="scroll-indicator">
        <div class="scroll-line"></div>
      </div>
      <span class="scroll-text">Scroll</span>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-900);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(230,57,70,0.08) 0%, transparent 70%);
  }

  /* Ambient glow orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: rgba(230, 57, 70, 0.12);
    top: -10%;
    right: -5%;
    animation: pulseGlow 8s ease-in-out infinite;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: rgba(142, 202, 230, 0.06);
    bottom: 10%;
    left: -8%;
    animation: pulseGlow 10s ease-in-out 2s infinite;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: rgba(230, 57, 70, 0.08);
    top: 50%;
    left: 60%;
    animation: pulseGlow 12s ease-in-out 4s infinite;
  }

  .mountains {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .mountain-svg {
    width: 100%;
    display: block;
    position: absolute;
    bottom: 0;
  }

  .mountain-back {
    height: 400px;
    opacity: 0.6;
  }

  .mountain-front {
    height: 380px;
  }

  .snow-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--white);
    padding: 140px 24px 100px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 22px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 36px;
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.6);
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--red);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--red-glow);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(3.5rem, 11vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    margin-bottom: 28px;
    letter-spacing: -0.04em;
  }

  .hero-line-1 {
    display: block;
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
    opacity: 0;
    color: var(--white);
  }

  .hero-line-2 {
    display: block;
    background: linear-gradient(90deg, var(--white), var(--frost-blue), var(--white));
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards,
               shimmer 6s linear 1.5s infinite;
    opacity: 0;
  }

  .hero-subtitle {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    max-width: 540px;
    margin: 0 auto 44px;
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
    color: rgba(255,255,255,0.5);
    font-weight: 400;
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.7s forwards;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 32px;
    border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.5px;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    cursor: pointer;
    border: none;
    text-transform: uppercase;
  }

  .btn-primary {
    background: var(--red);
    color: var(--white);
    box-shadow: 0 4px 24px rgba(230, 57, 70, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(230, 57, 70, 0.4);
    background: var(--red-dark);
  }

  .btn-ghost {
    background: transparent;
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.3);
    color: var(--white);
    transform: translateY(-3px);
  }

  .hero-scroll {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    opacity: 0;
    animation: fadeIn 1s ease 1.5s forwards;
  }

  .hero-scroll a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .scroll-indicator {
    width: 20px;
    height: 32px;
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-line {
    width: 2px;
    height: 8px;
    background: rgba(255,255,255,0.5);
    border-radius: 2px;
    animation: float 2s ease-in-out infinite;
  }

  .scroll-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 120px 16px 80px;
    }

    .mountain-back {
      height: 250px;
    }

    .mountain-front {
      height: 230px;
    }

    .orb-1 { width: 300px; height: 300px; }
    .orb-2 { width: 250px; height: 250px; }
    .orb-3 { display: none; }
  }
</style>

<script>
  // Snowfall / ice crystal effect
  const container = document.getElementById('snow-container');
  if (container) {
    for (let i = 0; i < 30; i++) {
      const snow = document.createElement('div');
      const size = Math.random() * 3 + 1.5;
      const opacity = Math.random() * 0.25 + 0.05;
      snow.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        background: rgba(255,255,255,${opacity});
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: -10px;
        animation: snowfall ${Math.random() * 10 + 8}s linear ${Math.random() * 8}s infinite;
        pointer-events: none;
      `;
      container.appendChild(snow);
    }
  }
</script>
