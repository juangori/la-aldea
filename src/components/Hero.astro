---
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="snow-container" id="snow-container"></div>
    <div class="mountains">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="none" class="mountain-svg">
        <!-- Back mountain range -->
        <path d="M0,400 L0,280 L200,180 L350,250 L500,120 L650,220 L720,100 L850,200 L1000,80 L1100,180 L1200,130 L1350,220 L1440,160 L1440,400 Z" fill="rgba(150,20,30,0.3)" />
        <!-- Front mountain range -->
        <path d="M0,400 L0,320 L150,240 L280,300 L420,180 L550,280 L700,150 L800,260 L950,140 L1100,250 L1250,190 L1440,280 L1440,400 Z" fill="rgba(196,30,42,0.5)" />
        <!-- Snow caps -->
        <path d="M420,180 L460,210 L440,200 L420,210 L400,200 L380,210 Z" fill="rgba(255,255,255,0.8)" />
        <path d="M700,150 L740,180 L720,170 L700,180 L680,170 L660,180 Z" fill="rgba(255,255,255,0.8)" />
        <path d="M950,140 L990,170 L970,160 L950,170 L930,160 L910,170 Z" fill="rgba(255,255,255,0.8)" />
        <path d="M500,120 L540,150 L520,140 L500,150 L480,140 L460,150 Z" fill="rgba(255,255,255,0.8)" />
        <path d="M1000,80 L1040,110 L1020,100 L1000,110 L980,100 L960,110 Z" fill="rgba(255,255,255,0.9)" />
      </svg>
    </div>
  </div>
  <div class="hero-content container">
    <div class="hero-badge">Fábrica & Distribución</div>
    <h1>
      <span class="hero-line-1">Hielo &</span>
      <span class="hero-line-2">Congelados</span>
    </h1>
    <p class="hero-subtitle">
      Producimos y distribuimos hielo y productos congelados de la más alta calidad para tu negocio, evento o consumo diario.
    </p>
    <div class="hero-cta">
      <a href="#contacto" class="btn btn-primary">
        <span>Contactanos</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="#calculadora" class="btn btn-secondary">Calcular hielo</a>
    </div>
  </div>
  <div class="hero-scroll">
    <a href="#servicios">
      <div class="scroll-indicator">
        <div class="scroll-dot"></div>
      </div>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(165deg, #1a0a0c 0%, #3d0f14 25%, var(--red-dark) 50%, var(--red) 75%, #e84350 100%);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .mountains {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .mountain-svg {
    width: 100%;
    height: 400px;
    display: block;
  }

  .snow-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--white);
    padding: 120px 24px 80px;
  }

  .hero-badge {
    display: inline-block;
    padding: 8px 24px;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 50px;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 32px;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.08);
    animation: fadeInUp 0.8s ease forwards;
  }

  h1 {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 24px;
  }

  .hero-line-1 {
    display: block;
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  .hero-line-2 {
    display: block;
    background: linear-gradient(90deg, #ffffff, #d0eaf4, #ffffff);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.8s ease 0.4s forwards, shimmer 4s linear infinite;
    opacity: 0;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    max-width: 600px;
    margin: 0 auto 40px;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.6s forwards;
    color: rgba(255,255,255,0.85);
    font-weight: 300;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.8s forwards;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    font-family: 'Outfit', sans-serif;
  }

  .btn-primary {
    background: var(--white);
    color: var(--red);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.4);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--white);
    transform: translateY(-3px);
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .scroll-indicator {
    width: 24px;
    height: 40px;
    border: 2px solid rgba(255,255,255,0.4);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: var(--white);
    border-radius: 2px;
    animation: float 2s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 100px 16px 60px;
    }

    .mountain-svg {
      height: 200px;
    }
  }
</style>

<script>
  // Snowfall effect
  const container = document.getElementById('snow-container');
  if (container) {
    for (let i = 0; i < 40; i++) {
      const snow = document.createElement('div');
      const size = Math.random() * 4 + 2;
      snow.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        background: rgba(255,255,255,${Math.random() * 0.4 + 0.2});
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: -10px;
        animation: snowfall ${Math.random() * 8 + 6}s linear ${Math.random() * 5}s infinite;
        pointer-events: none;
      `;
      container.appendChild(snow);
    }
  }
</script>
