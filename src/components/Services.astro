---
const services = [
  {
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="12" y="8" width="40" height="48" rx="4"/><path d="M22 28h20M32 18v20"/><circle cx="32" cy="38" r="3" fill="currentColor"/><path d="M20 56h24" stroke-linecap="round"/></svg>`,
    title: "Fábrica de Hielo",
    description: "Producimos hielo de la más alta pureza con agua tratada y filtrada. Bolsas de 4kg y 20kg disponibles.",
    features: ["Agua filtrada", "Bolsas 4kg y 20kg", "Producción continua"]
  },
  {
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="8" y="16" width="48" height="36" rx="4"/><path d="M8 28h48"/><circle cx="20" cy="40" r="4"/><circle cx="32" cy="40" r="4"/><circle cx="44" cy="40" r="4"/><path d="M24 8l8 8 8-8"/></svg>`,
    title: "Productos Congelados",
    description: "Amplia variedad de productos congelados de primeras marcas. Desde hamburguesas hasta mariscos.",
    features: ["Primeras marcas", "Variedad completa", "Cadena de frío garantizada"]
  },
  {
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="10" y="20" width="36" height="28" rx="3"/><path d="M18 20V14a14 14 0 0128 0v6"/><circle cx="28" cy="34" r="4"/><path d="M28 38v4"/><path d="M46 30h10l-4 18H46"/></svg>`,
    title: "Venta Minorista",
    description: "Visitá nuestro local y llevá todo lo que necesitás. Atención personalizada y los mejores precios.",
    features: ["Atención personalizada", "Mejores precios", "Local acondicionado"]
  },
  {
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 44h8l4-8h32l4 8h8"/><rect x="16" y="20" width="32" height="16" rx="3"/><circle cx="18" cy="48" r="4"/><circle cx="46" cy="48" r="4"/><path d="M24 28h16M32 24v8"/></svg>`,
    title: "Distribución",
    description: "Llevamos hielo y congelados hasta tu negocio o evento. Cobertura en toda la zona con flota propia.",
    features: ["Flota propia", "Cobertura zonal", "Entregas puntuales"]
  }
];
---

<section class="services" id="servicios">
  <div class="container">
    <div class="section-title fade-in">
      <h2>Nuestros <span class="accent">Servicios</span></h2>
      <div class="section-divider"></div>
      <p>Todo lo que necesitás en hielo y congelados, con la calidad y el compromiso que nos caracteriza</p>
    </div>
    <div class="services-grid">
      {services.map((service, i) => (
        <div class="service-card fade-in" style={`animation-delay: ${i * 0.15}s`}>
          <div class="service-icon" set:html={service.icon} />
          <h3>{service.title}</h3>
          <p>{service.description}</p>
          <ul class="service-features">
            {service.features.map(f => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 120px 0;
    background: var(--off-white);
    position: relative;
  }

  .services::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to bottom, var(--white), var(--off-white));
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
  }

  .service-card {
    background: var(--white);
    border-radius: 20px;
    padding: 40px 32px;
    transition: all 0.4s ease;
    border: 1px solid var(--gray-200);
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--red);
    transform: scaleX(0);
    transition: transform 0.4s ease;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(196, 30, 42, 0.1);
    border-color: transparent;
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  .service-icon {
    width: 56px;
    height: 56px;
    color: var(--red);
    margin-bottom: 24px;
  }

  .service-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  h3 {
    font-size: 1.4rem;
    margin-bottom: 12px;
    color: var(--gray-800);
    font-family: 'Outfit', sans-serif;
  }

  p {
    color: var(--gray-600);
    line-height: 1.7;
    margin-bottom: 20px;
    font-size: 0.95rem;
  }

  .service-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: var(--gray-600);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .services {
      padding: 80px 0;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .service-card {
      padding: 32px 24px;
    }
  }
</style>
